{
  "name": "data-portal-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "docs": "typedoc",
    "test": "vitest run --project storybook",
    "test:watch": "vitest --project storybook",
    "lint": "biome check .",
    "format": "biome format --write .",
    "sb": "bash scripts/dev.sh start",
    "stories": "bash scripts/dev.sh start",
    "sb:restart": "bash scripts/dev.sh restart",
    "sb:stop": "bash scripts/dev.sh stop",
    "sb:clean": "bash scripts/dev.sh clean",
    "sb:reset": "bash scripts/dev.sh reset",
    "sb:build": "storybook build -o dist/storybook",
    "stories:build": "storybook build -o dist/storybook",
    "serve:up": "bash scripts/dev.sh serve-up",
    "serve:down": "bash scripts/dev.sh serve-down",
    "serve:status": "bash scripts/dev.sh status",
    "up": "bash scripts/dev.sh up",
    "demo:build": "bash scripts/dev.sh demo-build",
    "demo": "bash scripts/dev.sh demo",
    "demo:up": "bash scripts/dev.sh demo-up",
    "demo:down": "bash scripts/dev.sh demo-down",
    "demo:stop": "bash scripts/dev.sh demo-stop"
  },
  "dependencies": {
    "@catppuccin/palette": "^1.8.0",
    "@emotion/is-prop-valid": "^1.4.0",
    "@rose-pine/palette": "^4.0.1",
    "@tanstack/react-virtual": "^3.10.0",
    "@use-gesture/react": "^10.3.1",
    "clsx": "^2.1.1",
    "culori": "^4.0.2",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-aria-components": "^1.17.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/react": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/culori": "^4.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "madge": "^8.0.0",
    "playwright": "^1.60.0",
    "remark-gfm": "^4.0.1",
    "storybook": "^10.4.1",
    "tailwindcss": "^4.0.0",
    "typedoc": "^0.28.19",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.7"
  }
