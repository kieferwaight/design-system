{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src"],
  "entryPointStrategy": "expand",
  "tsconfig": "tsconfig.json",
  "out": "docs",
  "exclude": [
    "**/*.stories.tsx",
    "**/*.stories.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.mdx",
    "**/mocks/**"
  ],
  "excludeExternals": true,
  "skipErrorChecking": true,
  "name": "data-portal-web"
}
